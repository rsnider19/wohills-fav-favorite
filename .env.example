# Local development: values come from `supabase status` after `supabase start`.
# Production: use your hosted Supabase project's URL and publishable (anon) key.
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_ANON_KEY=

# Voting window — ISO 8601 with timezone offset. Leave empty for no restriction.
# Applied to the database (where RLS enforces it) with `npm run set-window`,
# which needs the service-role key (local: printed by `supabase status`;
# hosted: Dashboard → Settings → API). Never ship this key to the browser.
VOTING_OPENS_AT=2026-07-04T12:00:00-05:00
VOTING_CLOSES_AT=2026-07-04T20:00:00-05:00
SUPABASE_SERVICE_ROLE_KEY=
